/* 营养素进度条组件 */

.nutrient-bar-container {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.nutrient-name {
  width: 100rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex-shrink: 0;
}

.bar-wrapper {
  flex: 1;
  padding: 0 20rpx;
}

.bar-bg {
  height: 12rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

.nutrient-value {
  width: 160rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: right;
  flex-shrink: 0;
}
