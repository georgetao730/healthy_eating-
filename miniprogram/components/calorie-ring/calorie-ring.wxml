<view class="calorie-ring-container" style="width:{{size}}rpx;height:{{size}}rpx;">
  <canvas type="2d" id="calorieCanvas" class="calorie-canvas"></canvas>
  <view class="calorie-text">
    <text class="calorie-current">{{displayCurrent}}</text>
    <text class="calorie-label">/ {{target}} 千卡</text>
  </view>
</view>
