/* 卡路里环形进度图组件 */

.calorie-ring-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calorie-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.calorie-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.calorie-current {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.calorie-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}
