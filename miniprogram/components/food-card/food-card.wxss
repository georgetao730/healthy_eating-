/* 食物信息卡片组件 */

.food-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--border-radius);
  margin-bottom: 20rpx;
}

.food-card-content {
  position: relative;
  z-index: 1;
  background-color: var(--card-bg);
  border-radius: var(--border-radius);
  transition: transform 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(248, 165, 182, 0.1);
}

.food-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
}

.food-main {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.food-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.food-amount {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.food-nutrients {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.food-calories {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-pink);
  margin-bottom: 10rpx;
}

.nutrient-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  color: #fff;
}

.tag-protein {
  background-color: #FF9F9F;
}

.tag-carbs {
  background-color: #A8D8B9;
}

.tag-fat {
  background-color: #FFD8A8;
  color: var(--text-primary);
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #FF6B6B;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 var(--border-radius) var(--border-radius) 0;
  z-index: 0;
}

.delete-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}
