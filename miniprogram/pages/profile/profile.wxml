<view class="profile-container">
  <!-- 用户信息区域 -->
  <view class="user-header">
    <view class="user-avatar-wrapper">
      <image 
        class="user-avatar" 
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" 
        mode="aspectFill"
      />
    </view>
    <view class="user-info">
      <text class="user-nickname">{{userInfo.nickName}}</text>
      <view wx:if="{{isLoggedIn && hasDueDate}}" class="pregnancy-info">
        <text class="pregnancy-week">孕{{pregnancyWeek}}周{{pregnancyDay}}天</text>
        <text class="pregnancy-stage">· {{stageName}}</text>
      </view>
      <view wx:if="{{!isLoggedIn}}" class="login-btn" bindtap="onLogin">
        <text class="login-text">点击登录</text>
      </view>
    </view>
  </view>

  <!-- 个人设置卡片 -->
  <view class="card setting-card">
    <view class="card-header">
      <text class="card-title">个人设置</text>
    </view>
    
    <!-- 预产期设置 -->
    <view class="setting-item">
      <text class="setting-label">预产期</text>
      <picker 
        mode="date" 
        value="{{userInfo.dueDate}}"
        start="{{getTodayString}}"
        end="2027-12-31"
        bindchange="onDueDateChange"
      >
        <view class="setting-value-wrapper">
          <text class="setting-value {{userInfo.dueDate ? '' : 'placeholder'}}">
            {{userInfo.dueDate || '请选择预产期'}}
          </text>
          <text class="arrow">></text>
        </view>
      </picker>
    </view>
    
    <view class="divider-line"></view>
    
    <!-- 身高设置 -->
    <view class="setting-item">
      <text class="setting-label">身高</text>
      <view class="setting-input-wrapper">
        <input 
          class="setting-input" 
          type="digit"
          value="{{userInfo.height}}"
          placeholder="请输入身高"
          bindblur="onHeightChange"
        />
        <text class="unit">cm</text>
      </view>
    </view>
    
    <view class="divider-line"></view>
    
    <!-- 孕前体重设置 -->
    <view class="setting-item">
      <text class="setting-label">孕前体重</text>
      <view class="setting-input-wrapper">
        <input 
          class="setting-input" 
          type="digit"
          value="{{userInfo.prePregnancyWeight}}"
          placeholder="请输入体重"
          bindblur="onWeightChange"
        />
        <text class="unit">kg</text>
      </view>
    </view>
  </view>

  <!-- 外卖点餐卡片 -->
  <view class="card takeout-card">
    <view class="card-header">
      <text class="card-title">快捷点餐</text>
    </view>
    <view class="takeout-buttons">
      <view class="takeout-btn eleme-btn" bindtap="goToEleme">
        <view class="btn-icon">🍔</view>
        <text class="btn-text">饿了么</text>
      </view>
      <view class="takeout-btn meituan-btn" bindtap="goToMeituan">
        <view class="btn-icon">🛵</view>
        <text class="btn-text">美团外卖</text>
      </view>
    </view>
  </view>

  <!-- 数据管理卡片 -->
  <view class="card data-card">
    <view class="card-header">
      <text class="card-title">数据管理</text>
    </view>
    
    <view class="data-item" bindtap="exportData">
      <text class="data-label export-label">导出数据</text>
      <text class="arrow">></text>
    </view>
    
    <view class="divider-line"></view>
    
    <view class="data-item" bindtap="clearData">
      <text class="data-label clear-label">清除所有数据</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 关于信息 -->
  <view class="version-info">
    <text class="version-text">孕期健康饮食管理 v{{version}}</text>
    <text class="copyright">记录每一餐，守护宝宝成长</text>
  </view>
</view>
