/* 添加记录页样式 */

.record-add-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #FFF5F7 0%, #FFFFFF 100%);
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #FFE4EC;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  height: 80rpx;
  background: #F8F8F8;
  border-radius: 40rpx;
  padding: 0 24rpx;
  border: 2rpx solid #F0F0F0;
  transition: all 0.2s ease;
}

.search-input-wrapper:focus-within {
  background: #FFFFFF;
  border-color: #FFB6C1;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #999999;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

.search-input::placeholder {
  color: #BBBBBB;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #DDDDDD;
  border-radius: 22rpx;
}

.clear-icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

/* 分类筛选 */
.category-tabs {
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
  white-space: nowrap;
}

.category-tabs-wrapper {
  display: flex;
  padding: 20rpx 30rpx;
}

.category-tab {
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #F5F5F5;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s ease;
}

.category-tab:last-child {
  margin-right: 0;
}

.category-tab.active {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF8BA7 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 139, 167, 0.25);
}

/* 食物列表 */
.food-list {
  flex: 1;
  padding: 0 30rpx;
}

.food-list-content {
  padding: 20rpx 0 40rpx;
}

.food-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F5F5F5;
  transition: all 0.2s ease;
}

.food-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  border-color: #FFE4EC;
}

.food-item-info {
  display: flex;
  flex-direction: column;
}

.food-item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.food-item-category {
  font-size: 24rpx;
  color: #999999;
}

.food-item-calorie {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.calorie-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF8BA7;
}

.calorie-unit {
  font-size: 22rpx;
  color: #BBBBBB;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #BBBBBB;
}

/* 遮罩层 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 200;
}

.detail-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 详情弹窗 */
.detail-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 85vh;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  transform: translateY(100%);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 201;
  display: flex;
  flex-direction: column;
}

.detail-popup.show {
  transform: translateY(0);
}

/* 弹窗头部 */
.detail-header {
  padding: 40rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.detail-title-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.detail-food-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 28rpx;
}

.close-icon {
  font-size: 28rpx;
  color: #999999;
}

.detail-food-calorie {
  font-size: 26rpx;
  color: #FF8BA7;
}

/* 弹窗内容 */
.detail-content {
  flex: 1;
  padding: 30rpx 40rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 份量设置 */
.amount-section {
  margin-bottom: 40rpx;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.amount-input {
  width: 200rpx;
  height: 88rpx;
  background: #FFF5F7;
  border: 2rpx solid #FFE4EC;
  border-radius: 20rpx;
  text-align: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #FF8BA7;
}

.amount-unit {
  font-size: 32rpx;
  color: #666666;
  margin-left: 20rpx;
}

.quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-amount-tag {
  padding: 16rpx 32rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.quick-amount-tag.active {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF8BA7 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(255, 139, 167, 0.25);
}

/* 营养预览 */
.nutrition-preview {
  margin-bottom: 40rpx;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.nutrition-item.highlight {
  background: linear-gradient(135deg, #FFF0F3 0%, #FFE4EC 100%);
  border: 2rpx solid #FFD6E0;
}

.nutrition-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.nutrition-item.highlight .nutrition-value {
  color: #FF8BA7;
  font-size: 32rpx;
}

.nutrition-label {
  font-size: 22rpx;
  color: #999999;
}

/* 餐次选择 */
.meal-section {
  margin-bottom: 40rpx;
}

.meal-options {
  display: flex;
  gap: 20rpx;
}

.meal-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: #F8F8F8;
  border-radius: 20rpx;
  transition: all 0.2s ease;
}

.meal-option.active {
  background: linear-gradient(135deg, #FFB6C1 0%, #FF8BA7 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 139, 167, 0.25);
}

.meal-option .meal-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.meal-option .meal-name {
  font-size: 24rpx;
  color: #666666;
}

.meal-option.active .meal-name {
  color: #FFFFFF;
}

/* 弹窗底部 */
.detail-footer {
  padding: 20rpx 40rpx 50rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
}

.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FF8BA7 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 139, 167, 0.35);
  transition: all 0.2s ease;
}

.save-button:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 139, 167, 0.25);
}

.save-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}
