/* 营养分析页样式 */

.container {
  min-height: 100vh;
  background-color: #FFF5F7;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 日期信息栏 */
.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.date-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.stage-badge {
  font-size: 24rpx;
  color: #FF8FA3;
  background-color: #FFE4E9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.standard-tip {
  font-size: 24rpx;
  color: #999;
}

/* 卡片通用样式 */
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 今日摄入概览卡片 */
.calorie-overview {
  background: linear-gradient(135deg, #FF8FA3 0%, #FFB8C4 100%);
  color: #fff;
}

.calorie-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.calorie-main {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.calorie-value {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.calorie-unit {
  font-size: 28rpx;
  opacity: 0.9;
}

.calorie-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.status-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.status-icon.good {
  background-color: #51CF66;
}

.status-icon.warning {
  background-color: #FF6B6B;
}

.status-icon.caution {
  background-color: #FFD43B;
  color: #333;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.status-text.good {
  color: #E8F5E9;
}

.status-text.warning {
  color: #FFEBEE;
}

.status-text.caution {
  color: #FFF8E1;
}

.calorie-target {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.target-text {
  font-size: 26rpx;
  opacity: 0.95;
}

/* 营养素区域 */
.nutrient-section {
  padding: 24rpx 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.nutrient-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 营养建议卡片 */
.suggestions-card {
  background: linear-gradient(135deg, #FFF8E7 0%, #FFF3D6 100%);
  border: 1rpx solid #FFE4B5;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background-color: rgba(255, 255, 255, 0.7);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
}

.suggestion-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.5;
  flex: 1;
}

/* 近7天趋势区域 */
.weekly-section {
  padding-bottom: 24rpx;
}

.chart-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
  font-weight: normal;
}

.weekly-chart {
  position: relative;
  height: 320rpx;
  margin-top: 20rpx;
  padding: 20rpx 0;
}

.chart-target-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 2rpx;
  border-top: 2rpx dashed #ccc;
  z-index: 1;
}

.target-label {
  position: absolute;
  right: 0;
  top: -24rpx;
  font-size: 20rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 100%;
  padding: 0 10rpx;
  position: relative;
  z-index: 2;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.bar-wrapper {
  width: 40rpx;
  height: 260rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background-color: #f9f9f9;
  border-radius: 8rpx 8rpx 0 0;
  overflow: hidden;
}

.bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s ease;
  min-height: 4rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
  font-weight: 500;
}

.bar-date {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 图表图例 */
.chart-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}
