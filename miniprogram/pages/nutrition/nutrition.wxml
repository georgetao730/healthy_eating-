<view class="container">
  <!-- 日期信息栏 -->
  <view class="date-header">
    <view class="date-info">
      <text class="date-text">{{today}}</text>
      <text class="stage-badge">{{stageName}}</text>
    </view>
    <text class="standard-tip" wx:if="{{standard}}">按{{stageName}}标准</text>
  </view>

  <!-- 今日摄入概览卡片 -->
  <view class="card calorie-overview">
    <view class="calorie-content">
      <view class="calorie-main">
        <text class="calorie-value">{{totalCalories}}</text>
        <text class="calorie-unit">千卡</text>
      </view>
      <view class="calorie-status">
        <block wx:if="{{calorieStatus === 'adequate'}}">
          <text class="status-icon good">✓</text>
          <text class="status-text good">达标</text>
        </block>
        <block wx:elif="{{calorieStatus === 'insufficient'}}">
          <text class="status-icon warning">!</text>
          <text class="status-text warning">不足</text>
        </block>
        <block wx:else>
          <text class="status-icon caution">↑</text>
          <text class="status-text caution">过量</text>
        </block>
      </view>
    </view>
    <view class="calorie-target" wx:if="{{standard}}">
      <text class="target-text">推荐摄入 {{standard.calories}} 千卡</text>
    </view>
  </view>

  <!-- 宏量营养素区域 -->
  <view class="card nutrient-section">
    <view class="section-header">
      <text class="section-title">宏量营养素</text>
    </view>
    <view class="nutrient-list">
      <nutrient-bar 
        wx:for="{{macroNutrients}}" 
        wx:key="name"
        name="{{item.name}}"
        current="{{item.current}}"
        target="{{item.target}}"
        unit="{{item.unit}}"
      />
    </view>
  </view>

  <!-- 微量营养素区域 -->
  <view class="card nutrient-section">
    <view class="section-header">
      <text class="section-title">微量营养素</text>
    </view>
    <view class="nutrient-list">
      <nutrient-bar 
        wx:for="{{microNutrients}}" 
        wx:key="name"
        name="{{item.name}}"
        current="{{item.current}}"
        target="{{item.target}}"
        unit="{{item.unit}}"
      />
    </view>
  </view>

  <!-- 营养建议卡片 -->
  <view class="card suggestions-card" wx:if="{{suggestions.length > 0}}">
    <view class="section-header">
      <text class="section-title">💡 营养建议</text>
    </view>
    <view class="suggestion-list">
      <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="index">
        <text class="suggestion-icon" style="color: {{item.color}};">{{item.icon}}</text>
        <text class="suggestion-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 近7天趋势区域 -->
  <view class="card weekly-section">
    <view class="section-header">
      <text class="section-title">近7天摄入趋势</text>
      <text class="chart-subtitle">卡路里 (千卡)</text>
    </view>
    <view class="weekly-chart">
      <!-- 推荐值虚线 -->
      <view class="chart-target-line" style="bottom: {{targetLinePosition}}%;">
        <text class="target-label">推荐</text>
      </view>
      <!-- 柱状图 -->
      <view class="chart-bars">
        <view class="chart-bar-item" wx:for="{{weeklyData}}" wx:key="date">
          <view class="bar-wrapper">
            <view 
              class="bar" 
              style="height: {{item.percentage}}%; background-color: {{item.barColor}};"
            ></view>
          </view>
          <text class="bar-value">{{item.calories}}</text>
          <text class="bar-date">{{item.shortDate}}</text>
        </view>
      </view>
    </view>
    <view class="chart-legend">
      <view class="legend-item">
        <view class="legend-dot" style="background-color: #51CF66;"></view>
        <text class="legend-text">适量</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot" style="background-color: #FF6B6B;"></view>
        <text class="legend-text">不足</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot" style="background-color: #FFD43B;"></view>
        <text class="legend-text">过量</text>
      </view>
    </view>
  </view>
</view>
