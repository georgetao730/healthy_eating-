<view class="page-container">
  <!-- 分类选择栏 -->
  <scroll-view class="category-bar" scroll-x="true" show-scrollbar="false">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{currentCategory === item.key ? 'active' : ''}}"
        data-category="{{item.key}}"
        bindtap="switchCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 转盘区域 -->
  <view class="wheel-section">
    <lucky-wheel
      id="luckyWheel"
      items="{{wheelItems}}"
      spinning="{{spinning}}"
      bindresult="onWheelResult"
    />
  </view>

  <!-- 换一批按钮 -->
  <view class="refresh-btn" bindtap="refreshWheel">
    <text class="refresh-icon">🔄</text>
    <text class="refresh-text">换一批</text>
  </view>

  <!-- 结果展示弹窗 -->
  <view class="result-mask {{showResult ? 'show' : ''}}" bindtap="closeResult">
    <view class="result-popup {{showResult ? 'show' : ''}}" catchtap="preventBubble">
      <!-- 关闭按钮 -->
      <view class="close-btn" bindtap="closeResult">×</view>

      <!-- 食物名称 -->
      <view class="result-header">
        <text class="result-title">今天吃这个！</text>
        <text class="result-food-name">{{resultFood.name}}</text>
      </view>

      <!-- 营养信息 -->
      <view class="nutrition-section" wx:if="{{resultFood}}">
        <text class="section-title">每100g营养含量</text>
        <view class="nutrition-grid">
          <view class="nutrition-item">
            <text class="nutrition-value">{{resultFood.calories}}</text>
            <text class="nutrition-unit">kcal</text>
            <text class="nutrition-label">热量</text>
          </view>
          <view class="nutrition-item">
            <text class="nutrition-value">{{resultFood.protein}}g</text>
            <text class="nutrition-label">蛋白质</text>
          </view>
          <view class="nutrition-item">
            <text class="nutrition-value">{{resultFood.carbs}}g</text>
            <text class="nutrition-label">碳水</text>
          </view>
          <view class="nutrition-item">
            <text class="nutrition-value">{{resultFood.fat}}g</text>
            <text class="nutrition-label">脂肪</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-buttons">
        <view class="btn btn-primary" bindtap="goToRecord">
          <text class="btn-icon">📝</text>
          <text>记录到饮食</text>
        </view>
        <view class="btn btn-secondary" bindtap="spinAgain">
          <text class="btn-icon">🎲</text>
          <text>再转一次</text>
        </view>
      </view>

      <!-- 外卖跳转 -->
      <view class="delivery-section">
        <text class="delivery-title">不想做？去点外卖</text>
        <view class="delivery-buttons">
          <view class="delivery-btn eleme" bindtap="goToEleme">
            <text class="delivery-icon">🥡</text>
            <text>饿了么</text>
          </view>
          <view class="delivery-btn meituan" bindtap="goToMeituan">
            <text class="delivery-icon">🛵</text>
            <text>美团</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
