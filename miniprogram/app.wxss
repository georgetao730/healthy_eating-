/* 全局样式 - 温馨柔和的孕期主题 */

/* CSS 变量定义 */
page {
  --primary-pink: #F8A5B6;
  --primary-green: #A8D8B9;
  --bg-color: #FFF5F7;
  --text-primary: #333;
  --text-secondary: #666;
  --text-light: #999;
  --card-bg: #FFFFFF;
  --border-radius: 16rpx;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 页面基础样式 */
page {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background-color: var(--card-bg);
  border-radius: var(--border-radius);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(248, 165, 182, 0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.card-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* 通用按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-pink), #FFB5C5);
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: var(--primary-green);
  color: #fff;
}

.btn-secondary:active {
  opacity: 0.8;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--primary-pink);
  color: var(--primary-pink);
}

/* 文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-light {
  color: var(--text-light);
}

.text-pink {
  color: var(--primary-pink);
}

.text-green {
  color: var(--primary-green);
}

/* 标题样式 */
.title-lg {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.title-md {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.title-sm {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

/* 间距工具类 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 圆角卡片式布局 */
.rounded-card {
  background-color: var(--card-bg);
  border-radius: 24rpx;
  overflow: hidden;
}

/* 阴影效果 */
.shadow-soft {
  box-shadow: 0 4rpx 20rpx rgba(248, 165, 182, 0.1);
}

.shadow-medium {
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

/* 空状态提示 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-light);
}

.empty-state text {
  margin-top: 20rpx;
  font-size: 28rpx;
}
